{
  "name": "cadlad-mcp-server",
  "version": "0.1.0",
  "description": "MCP server — assistant bridge for CadLad live sessions",
  "type": "module",
  "main": "dist/server.js",
  "bin": {
    "cadlad-mcp": "./dist/server.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint src",
