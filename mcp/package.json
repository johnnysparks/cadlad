    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.37.0",
    "@types/node": "^20.0.0",
    "eslint": "^9.37.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.46.1",
    "vitest": "^4.1.2"
  }
}
