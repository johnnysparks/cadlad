{
  "name": "cadlad-live-sessions",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "wrangler dev --config wrangler.toml",
    "deploy": "npm run typecheck && wrangler deploy --config wrangler.toml",
    "deploy:dry": "npm run typecheck && wrangler deploy --dry-run --outdir .wrangler-dist --config wrangler.toml",
    "lint": "node ../node_modules/eslint/bin/eslint.js src test vitest.config.ts",
    "test": "node scripts/run-vitest.mjs test/ci.smoke.test.ts",
    "test:full": "node scripts/run-vitest.mjs --exclude test/session.test.ts",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "test:oauth": "node scripts/run-vitest.mjs test/session.test.ts"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.14.0",
    "@cloudflare/workers-types": "^4.20241106.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.2",
    "wrangler": "^3.94.0"
  }
}
